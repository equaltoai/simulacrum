{
	"name": "simulacrum",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/externalize-sveltekit-bootstrap.mjs && node scripts/externalize-sveltekit-announcer.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"api:contracts": "node scripts/update-contracts.mjs",
		"api:test": "node scripts/api-test.mjs",
		"test": "node --test tests/api/_harness/redact.test.mjs"
	},
	"devDependencies": {
		"ajv": "^8.17.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.53.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"yaml": "^2.8.1"
	},
	"dependencies": {
		"@apollo/client": "^4.1.4",
		"@apollo/client-react-streaming": "^0.14.4",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@noble/hashes": "^2.0.1",
		"@tanstack/svelte-virtual": "^3.13.18",
		"acorn": "^6.4.0",
		"focus-trap": "^8.0.0",
		"graphql": "^16.12.0",
		"graphql-ws": "^6.0.7",
		"hast-util-sanitize": "^5.0.2",
		"hast-util-to-mdast": "^10.1.2",
		"mdast-util-gfm": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"rehype-parse": "^9.0.1",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"shiki": "^3.22.0",
		"tabbable": "^6.4.0",
		"unified": "^11.0.5"
	}
}
